{
  "$schema": "https://opencode.ai/config.json",

  // Default agent when none is specified by the user.
  // "pm" orchestrates the entire Samourai pipeline end to end.
  "default_agent": "pm",

  // ─── Global Models ────────────────────────────────────────────────────────

  // Fallback model used by any agent without an explicit "model" in the "agent" section.
  // Format: "provider/model-id"
  "model": "github-copilot/gpt-5.2",

  // Lightweight model for non-critical utility tasks:
  // session title generation, short summaries, metadata.
  "small_model": "github-copilot/gpt-5-mini",

  // ─── Global Instructions ───────────────────────────────────────────────────

  // Files automatically loaded and injected into the context of ALL agents.
  // Propagates repository conventions without repeating them in each agent prompt.
  // Paths are relative to the project root.
  "instructions": [
    ".samourai/core/governance/conventions/unified-change-convention-tracker-agnostic-specification.md",
    ".samourai/core/governance/conventions/change-lifecycle.md",
    ".samourai/core/governance/policies/agent-permissions.yaml",
    // Generated by /bootstrap — project complexity profile (TMA/Build/Guide/Mix).
    // This file does not exist before the first /bootstrap run. Agents ignore it when absent.
    ".samourai/ai/agent/project-profile.md"
  ],

  // ─── MCP Servers ────────────────────────────────────────────────────────────

  // MCP = Model Context Protocol: extension protocol for connecting external tools
  // (GitHub, databases, APIs, etc.) to agents via a local or remote server.
  //
  // All servers are disabled by default (enabled: false).
  // Enable only when prerequisites are met (token, npx, network, etc.).
  //
  // ⚠️  The npx in "command" is only used to launch the MCP server —
  //     it is NOT a method for installing OpenCode.
  //     OpenCode installation: curl -fsSL https://opencode.ai/install | bash
  "mcp": {

    // Official GitHub MCP server.
    // Provides access to github* tools: issues, PRs, reviews, labels, comments.
    // Required by @pm (clarify_scope), @pr-manager (PR creation), @reviewer (remote mode).
    //
    // To enable:
    //   1. Set the environment variable: export GITHUB_API_TOKEN=ghp_xxx
    //   2. Set "enabled": true
    //   3. Uncomment "tools": { "github*": true } in the "agent" section
    "github-mcp": {
      "type": "local",                        // type "local" = process launched as a subprocess
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        // {env:VAR} = reference to an environment variable from the host shell.
        // Never store the token in plain text here.
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_API_TOKEN}"
      },
      "enabled": false                         // enable for @pm (GitHub MCP tools)
    },

    // Context7 MCP server (Upstash).
    // Provides up-to-date technical documentation and code examples.
    // Used by @external-researcher to enrich searches without hallucinating.
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": false                        // enable if @external-researcher is used heavily
    },

    // ── Atlassian (Jira + Confluence) ────────────────────────────────────────
    // MCP server for Jira and Confluence.
    // Provides access to issues, sprints, and Confluence documentation pages.
    // Alternative to github-mcp for teams on the Atlassian stack.
    // Used by @pm (clarify_scope, ticket transitions), @spec-writer (Confluence pages).
    //
    // Prerequisites:
    //   export JIRA_URL=https://yourcompany.atlassian.net
    //   export JIRA_EMAIL=you@company.com
    //   export JIRA_TOKEN=your_api_token   # https://id.atlassian.com/manage-profile/security/api-tokens
    "atlassian-mcp": {
      "type": "local",
      "command": ["npx", "-y", "mcp-atlassian"],
      "environment": {
        "JIRA_URL":   "{env:JIRA_URL}",
        "JIRA_EMAIL": "{env:JIRA_EMAIL}",
        "JIRA_TOKEN": "{env:JIRA_TOKEN}"
      },
      "enabled": false
    },

    // ── Persistent Memory ──────────────────────────────────────────────────
    // Local knowledge graph that persists across OpenCode sessions.
    // Allows @pm to retain decisions, project context, and patterns
    // discovered across deliveries — without repeating them each session.
    //
    // Data stored locally in ~/.local/share/opencode/memory/ (or equivalent).
    // No data is sent externally.
    //
    // Typical usage: @pm stores architectural decisions, project preferences,
    // and cross-change context to resume sessions without loss of information.
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": false                         // enable for long-running projects
    },

    // ── Extended Filesystem ────────────────────────────────────────────────
    // Read/write access to paths outside the current repository.
    // Useful for @bootstrapper (installing the kit into another project)
    // and for accessing resources shared across multiple repositories.
    //
    // ⚠️  Restrict exposed paths to the strict minimum (principle of least privilege).
    // Replace /tmp with the path(s) actually required.
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "enabled": false                        // enable and adjust the path as needed
    },

    // ── Sequential Thinking ──────────────────────────────────────────────────
    // MCP server that enforces structured step-by-step reasoning.
    // Improves the quality of complex decisions by preventing cognitive shortcuts.
    //
    // Particularly useful for:
    //   @architect   — decomposing an architectural problem
    //   @pm          — risk and dependency analysis for a change
    //   @plan-writer — building a rigorous implementation plan
    //
    // No prerequisites — works offline.
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false                        // enable for agents requiring complex reasoning
    },

    // ── Puppeteer (browser automation) ──────────────────────────────────────
    // Controls a headless Chromium browser from agents.
    // Enables: navigation, clicking, form filling, screenshots,
    // and JavaScript execution in the browser.
    //
    // Samourai use cases:
    //   @designer       — capture UI screenshots for visual reviews
    //   @runner         — run E2E browser tests when the project has no CLI test runner
    //   @image-reviewer — analyze the actual visual rendering of a page
    //
    // Prerequisites: Chromium installed (installed automatically by puppeteer-mcp-server).
    "puppeteer": {
      "type": "local",
      "command": ["npx", "-y", "puppeteer-mcp-server"],
      "enabled": false                         // enable for browser tests and UI screenshots
    }
  },

  // ─── Global Permissions ────────────────────────────────────────────────────

  // Rule applied to ALL agents unless explicitly overridden in the "agent" section.
  // "github*": disables all GitHub MCP tools by default (wildcard).
  // Each agent that needs them must enable them explicitly.
  "tools": {
    "github*": false
  },

  // ─── Context Compaction ─────────────────────────────────────────────────────

  // Controls automatic context management when the context window is full.
  // Essential for long deliveries (e.g., /run-plan with 7+ phases).
  "compaction": {
    // auto: true = OpenCode compacts automatically when the context is nearly full.
    // false = the session crashes or truncates silently.
    "auto": true,

    // prune: true = removes old, stale tool outputs (bash, read, etc.).
    // Frees space without losing the conversation logic.
    "prune": true,

    // Number of recent user turns (and their responses) preserved verbatim during
    // compaction. Older turns are summarized.
    // 3 = keep the last 3 complete exchanges intact (OpenCode default: 2).
    "tail_turns": 3
  },

  // ─── Watcher ─────────────────────────────────────────────────────────────────

  // The watcher monitors file changes to trigger reloads.
  // "ignore": path patterns to exclude in order to avoid noise and false triggers.
  "watcher": {
    "ignore": [
      ".git-workflow",  // temporary artifacts from the /git-workflow pipeline
      "tmp",            // temporary files from agents (@committer, @runner)
      ".samourai"       // kit installation manifests (non-code)
    ]
  },

  // ─── Experimental ────────────────────────────────────────────────────────────

  // Preview features — stable in practice but not yet generally available.
  "experimental": {
    // batch_tool: enables the "batch" tool, allowing an agent to execute
    // multiple actions in parallel in a single call.
    // Useful for @runner (running build + tests simultaneously)
    // and @pm (triggering spec-writer + test-plan-writer in parallel).
    "batch_tool": true
  },

  // ─── Agents ──────────────────────────────────────────────────────────────────

  // Individual configuration for each agent.
  // Available keys per agent:
  //   model       : LLM model to use (overrides the global "model")
  //   steps       : maximum number of agentic iterations before a forced response
  //                 (1 step = 1 cycle: LLM thinks → calls tool → receives result)
  //   temperature : model creativity (0.0 = deterministic, 1.0 = creative)
  //   permission  : tool access rights ("allow" | "deny" | "ask")
  //                 Can be a global string or a per-tool object.
  //   color       : identification color in the OpenCode UI
  //                 Values: "primary" | "secondary" | "accent" | "success" |
  //                         "warning" | "error" | "info" | "#RRGGBB"
  "agent": {

    // ── Primary Orchestrator ──────────────────────────────────────────────────

    // @pm: master orchestrator of the Samourai pipeline.
    // Full access required to read/write artifacts, call sub-agents,
    // and interact with trackers (GitHub MCP when enabled).
    "pm": {
      "model": "github-copilot/claude-opus-4.6",
      "steps": 200,           // long orchestration: many possible steps
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "webfetch": "allow"
      },
      "color": "primary",
      "tools": { "github*": true }  // explicitly enables GitHub MCP tools for @pm
    },

    // ── Implementation ───────────────────────────────────────────────────────

    // @coder: implements plan phases. Reads, writes, and runs commands.
    // No web access — works exclusively within the repository.
    "coder": {
      "model": "github-copilot/gpt-5.3-codex",
      "steps": 220,            // multi-phase implementation: many file operations
      "permission": {
        "bash": "allow",      // run commands (tests, build, typecheck)
        "edit": "allow",      // modify files
        "read": "allow",      // read files
        "glob": "allow",      // search files by pattern
        "grep": "allow",      // search file contents
        "task": "allow",      // delegate to sub-agents
        "webfetch": "deny"    // no internet access — works within the repository
      }
    },

    // @fixer: fixes bugs and test failures using root-cause analysis.
    // Similar access to @coder but fewer steps (targeted investigation).
    "fixer": {
      "model": "github-copilot/gpt-5.3-codex",
      "steps": 120,            // targeted debugging — should not wander too long
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },

    // @refactor: performs safe, incremental code refactoring.
    // Preserves behavior and validates with tests.
    "refactor": {
      "model": "github-copilot/gpt-5.3-codex", // same model as @coder
      "steps": 60,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    },

    // ── TDD ──────────────────────────────────────────────────────────────────

    // @tdd-orchestrator: enforces the red-green-refactor cycle for a task.
    // Delegated by @coder in /run-plan when the tdd-orchestrator skill is active.
    "tdd-orchestrator": {
      "model": "github-copilot/gpt-5.3-codex",
      "steps": 60,            // RED→GREEN→REFACTOR cycle × N behaviors
      "permission": {
        "bash": "allow",      // run tests at each step of the cycle
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "color": "accent"
    },

    // ── Review ───────────────────────────────────────────────────────────────

    // @reviewer: validates code against spec + plan + quality heuristics.
    // May modify the plan (adding a remediation phase) but not the source code.
    "reviewer": {
      "model": "github-copilot/gpt-5.3-codex",
      "temperature": 0.2,     // deterministic review: reduces variability in findings
      "steps": 30,            // diff reading + report = bounded task
      "permission": {
        "bash": "allow",      // git diff, git log to analyze the diff
        "edit": "allow",      // modify the plan only (remediation phase)
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"    // local review only
      }
      // To enable GitHub MCP on @reviewer (remote mode):
      // "tools": { "github*": true }
    },

    // @code-reviewer: targeted diff analysis — security, correctness, performance.
    // Delegated by @reviewer and /git-workflow. Strict read-only: modifies NOTHING.
    "code-reviewer": {
      "model": "github-copilot/gpt-5.3-codex",
      "temperature": 0.2,     // consistent and reproducible findings
      "steps": 20,            // bounded analysis — no action, report only
      "permission": {
        "bash": "deny",       // strict read-only: no commands
        "edit": "deny",       // never modifies source code
        "read": "allow",      // read files to understand context
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      },
      "color": "warning"      // orange = caution, findings require attention
    },

    // @gap-analysis: artifact traceability analysis (spec/plan/test/code gaps).
    // Similar to @code-reviewer but focused on lifecycle coverage.
    "gap-analysis": {
      "model": "github-copilot/gpt-5.3-codex", // same model as @reviewer
      "temperature": 0.2,     // deterministic analysis for reproducible reports
      "steps": 25,
      "permission": {
        "bash": "deny",      // read-only analysis; no command execution
        "edit": "deny",      // does not edit existing files
        "write": "allow",    // can write a dedicated gap report
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      },
      "color": "warning"
    },

    // @verdict: final GO/NO-GO evaluator based on gates and evidence.
    "verdict": {
      "model": "github-copilot/gpt-5.3-codex", // same model as @reviewer
      "temperature": 0.1,     // highly deterministic for consistent verdicts
      "steps": 20,
      "permission": {
        "bash": "allow",     // may inspect git and quality-gate outputs
        "edit": "deny",      // no source modifications
        "write": "allow",    // can produce a verdict report
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      },
      "color": "error"
    },

    // @jira-analysis: analyzes ticket quality and extracts requirements.
    "jira-analysis": {
      "model": "github-copilot/gpt-5.3-codex", // same model as @reviewer
      "temperature": 0.2,
      "steps": 20,
      "permission": {
        "bash": "allow",     // can inspect local artifacts and history if needed
        "edit": "deny",      // analysis only
        "write": "allow",    // can write structured analysis reports
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      },
      "color": "info"
    },

    // @review-feedback-applier: applies review feedback after human validation.
    "review-feedback-applier": {
      "model": "github-copilot/gpt-5.2-codex",
      "steps": 30
      // To enable GitHub MCP (read PR comments):
      // "tools": { "github*": true }
    },

    // ── Git / PR ─────────────────────────────────────────────────────────────

    // @committer: creates exactly one Conventional Commit. Simple and fast task.
    "committer": {
      "model": "github-copilot/gpt-5-mini", // lightweight model sufficient for git operations
      "steps": 15,            // git add + diff analysis + commit = few steps
      "permission": {
        "bash": "allow",      // git status, git add, git commit
        "edit": "allow",      // write the temporary commit message file
        "read": "allow",
        "webfetch": "deny"
      }
    },

    // @pr-manager: creates/updates the PR and stops before merge.
    "pr-manager": {
      "model": "github-copilot/claude-sonnet-4.5",
      "steps": 20
      // To enable GitHub MCP (create PR via API):
      // "tools": { "github*": true }
    },

    // ── Documentation & Specs ────────────────────────────────────────────────

    // @spec-writer: writes the change specification (chg-xxx-spec.md).
    "spec-writer": {
      "model": "github-copilot/claude-sonnet-4.6", // Claude: best for structured writing
      "steps": 30
    },

    // @test-plan-writer: writes the test plan (chg-xxx-test-plan.md).
    "test-plan-writer": {
      "model": "github-copilot/gpt-5.2",
      "steps": 25
    },

    // @plan-writer: writes the implementation plan (chg-xxx-plan.md).
    "plan-writer": {
      "model": "github-copilot/gpt-5.2",
      "steps": 50
    },

    // @doc-syncer: synchronizes system documentation with delivered code.
    // Reads the diff and updates doc/spec/. No web access.
    "doc-syncer": {
      "model": "github-copilot/claude-sonnet-4.5",
      "steps": 20,
      "permission": {
        "bash": "allow",      // git diff to see what changed
        "edit": "allow",      // update the docs
        "read": "allow",
        "webfetch": "deny"
      }
    },

    // ── Quality ──────────────────────────────────────────────────────────────

    // @runner: executes commands (build, tests, lint) and logs the results.
    // Does not modify source files — read and execute only.
    "runner": {
      "model": "github-copilot/gpt-5-mini", // execution task, no complex reasoning required
      "steps": 25,
      "permission": {
        "bash": "allow",      // run build, tests, lint, quality gates
        "read": "allow",      // read configs (package.json, Makefile, etc.)
        "edit": "deny"        // does not modify files — that is @fixer's role
      },
      "tools": { "puppeteer*": true }  // enables Puppeteer MCP for E2E browser tests
    },

    // ── Architecture & Tooling ─────────────────────────────────────────────

    // @architect: technical and architectural decisions. Produces ADRs.
    // Most powerful model for complex reasoning.
    "architect": {
      "model": "github-copilot/gpt-5.4",  // best model for architectural thinking
      "steps": 40,
      "color": "secondary"
    },

    // @bootstrapper: onboards a new project into the Samourai ecosystem.
    "bootstrapper": {
      "model": "github-copilot/claude-sonnet-4.6",
      "steps": 30
    },

    // @toolsmith: creates and improves kit tools, agents, and commands.
    "toolsmith": {
      "model": "github-copilot/gpt-5.3-codex",
      "steps": 40
    },

    // ── Content & Media ─────────────────────────────────────────────────────

    // @editor: writes and translates user-facing content per copywriting.md.
    "editor": {
      "model": "github-copilot/claude-sonnet-4.6", // Claude: best for natural language
      "steps": 20
    },

    // @designer: UI/UX design, aligned with the design system.
    "designer": {
      "model": "github-copilot/gpt-4o",    // GPT-4o: vision + design
      "steps": 20,
      "tools": { "puppeteer*": true }  // enables Puppeteer MCP for UI screenshots
    },

    // @image-generator: image generation via text-to-image.
    "image-generator": {
      "model": "github-copilot/gpt-4o",
      "steps": 10               // single generation = few steps
    },

    // @image-reviewer: analyzes screenshots and visual artifacts. Read-only.
    "image-reviewer": {
      "model": "github-copilot/gpt-4o",   // GPT-4o: multimodal (vision)
      "steps": 10,
      "permission": {
        "edit": "deny",         // analysis only, modifies nothing
        "bash": "deny"
      }
    },

    // ── Research ────────────────────────────────────────────────────────────

    // @external-researcher: research via web and MCP (context7, deepwiki, etc.).
    // Only agent authorized to leave the repository — webfetch and websearch enabled.
    "external-researcher": {
      "model": "github-copilot/gemini-3.1-pro-preview", // Gemini: large context window for research
      "steps": 30,
      "permission": {
        "webfetch": "allow",    // fetch web pages and documentation
        "websearch": "allow",   // web search
        "edit": "deny",         // modifies nothing — produces a report only
        "bash": "deny"
      }
    }
  }
}
